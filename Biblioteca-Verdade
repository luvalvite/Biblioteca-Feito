    biblioteca.adicionar_livro("Memorias Postumas", "Machado de Assis", "978-85-5678")
    biblioteca.adicionar_livro("Capitaes da Areia", "Jorge Amado", "978-85-9012")
    biblioteca.adicionar_livro("Angu de Sangue", "Joao Antonio", "978-85-3456")
    biblioteca.adicionar_livro("Vidas Secas", "Graciliano Ramos", "978-85-7890")
    
    biblioteca.listar_todos()
    
    # Mudando criterio de ordenacao para autor
    print("\n2. MUDANDO CRITERIO DE ORDENACAO PARA AUTOR:")
    biblioteca.set_criterio_ordenacao("autor")
    
    # Adicionando mais livros (serao ordenados por autor)
    biblioteca.adicionar_livro("Quarto de Despejo", "Carolina Maria de Jesus", "978-85-2345")
    biblioteca.adicionar_livro("Padre e Mooca", "Plinio Marcos", "978-85-6789")
    
    biblioteca.listar_todos()
    
    # Busca por titulo
    print("\n3. BUSCA POR TITULO:")
    biblioteca.buscar_por_titulo("Vidas Secas")
    biblioteca.buscar_por_titulo("Harry Potter")
    
    # Busca por autor
    print("\n4. BUSCA POR AUTOR:")
    biblioteca.buscar_por_autor("Machado de Assis")
    biblioteca.buscar_por_autor("Jorge Amado")
    
    # Emprestimo de livros
    print("\n5. EMPRESTIMO DE LIVROS:")
    biblioteca.emprestar_livro("978-85-1234")  # Dom Casmurro
    biblioteca.emprestar_livro("978-85-9012")  # Capitaes da Areia
    
    biblioteca.listar_todos()
    
    # Devolucao de livros
    print("\n6. DEVOLUCAO DE LIVROS:")
    biblioteca.devolver_livro("978-85-1234")  # Dom Casmurro
    
    biblioteca.listar_todos()
    
    # Remocao de livro
    print("\n7. REMOCAO DE LIVRO:")
    biblioteca.remover_livro("978-85-3456")  # Angu de Sangue
    
    biblioteca.listar_todos()
    
    print(f"\nTotal de livros na biblioteca: {biblioteca.obter_tamanho()}")
